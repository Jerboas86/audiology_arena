{
	"name": "audiology-arena",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"deploy": "wrangler deploy",
		"preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
		"prepare": "pnpm run types && svelte-kit sync || echo '' && husky",
		"check": "svelte-kit sync && pnpm run generated:postprocess && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && pnpm run generated:postprocess && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && oxlint .",
		"lint:fix": "oxlint --fix .",
		"test:unit": "vitest",
		"test": "pnpm run test:unit -- --run",
		"e2e": "playwright test",
		"types": "wrangler types && pnpm run generated:postprocess",
		"generated:postprocess": "node scripts/postprocess-generated-files.mjs",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio"
	},
	"devDependencies": {
		"@aws-sdk/client-s3": "^3.1020.0",
		"@inlang/paraglide-js": "^2.15.1",
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "7.0.0",
		"@types/node": "^25.5.0",
		"@vitest/browser-playwright": "^4.1.2",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"globals": "^17.4.0",
		"husky": "^9.1.7",
		"oxlint": "^1.57.0",
		"playwright": "^1.58.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.55.1",
		"svelte-check": "^4.4.5",
		"typescript": "^6.0.2",
		"vite": "^8.0.3",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.1.2",
		"vitest-browser-svelte": "^2.1.0",
		"wrangler": "^4.78.0"
	},
	"dependencies": {
		"@neondatabase/serverless": "^1.0.2"
	}
}
