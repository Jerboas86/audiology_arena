{
	"name": "audiology-arena",
	"private": true,
	"version": "0.0.1",
	"packageManager": "pnpm@11.7.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"deploy": "wrangler deploy",
		"preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
		"prepare": "pnpm run types && svelte-kit sync || echo '' && husky",
		"check": "svelte-kit sync && pnpm run generated:postprocess && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && pnpm run generated:postprocess && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && oxlint .",
		"lint:fix": "oxlint --fix .",
		"test": "vitest run",
		"e2e": "playwright test",
		"types": "wrangler types && pnpm run generated:postprocess",
		"generated:postprocess": "node scripts/postprocess-generated-files.mjs",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio"
	},
	"devDependencies": {
		"@aws-sdk/client-s3": "^3.1071.0",
		"@inlang/paraglide-js": "^2.20.0",
		"@playwright/test": "^1.61.0",
		"@sveltejs/adapter-cloudflare": "^7.2.9",
		"@sveltejs/kit": "^2.65.2",
		"@sveltejs/vite-plugin-svelte": "7.0.0",
		"@types/node": "^25.9.3",
		"@vitest/browser-playwright": "^4.1.9",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"globals": "^17.6.0",
		"husky": "^9.1.7",
		"oxlint": "^1.70.0",
		"playwright": "^1.61.0",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^3.5.2",
		"svelte": "^5.56.3",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.1.9",
		"vitest-browser-svelte": "^2.1.1",
		"wrangler": "^4.101.0"
	},
	"dependencies": {
		"@neondatabase/serverless": "^1.1.0"
	}
}
